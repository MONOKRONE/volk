  introDialogue:
  - speakerName: Organizator
    speakerPortrait: {fileID: 0}
    text: VOLK turnuvasinin finali! Kazanan bir dilek hakkina sahip olacak.
    isPlayerSpeaking: 0
  - speakerName: YBot
    speakerPortrait: {fileID: 0}
    text: Sonunda yuzyuze geldik. Bu turnuvayi ben kurdum.
    isPlayerSpeaking: 0
  - speakerName: Volk
    speakerPortrait: {fileID: 0}
    text: Neden kendi turnuvana katildin?
    isPlayerSpeaking: 1
  - speakerName: YBot
    speakerPortrait: {fileID: 0}
    text: Cunku dilegi hak eden tek kisi benim. Sen sadece bir pionssun.
    isPlayerSpeaking: 0
  - speakerName: Volk
    speakerPortrait: {fileID: 0}
    text: Piyon degilim. Ve bu gece bitiyor.
    isPlayerSpeaking: 1
  outroDialogue:
  - speakerName: YBot
    speakerPortrait: {fileID: 0}
    text: Bu... mumkun degil...
    isPlayerSpeaking: 0
  - speakerName: Organizator
    speakerPortrait: {fileID: 0}
    text: 'Kazanan: VOLK! Dilegi nedir?'
    isPlayerSpeaking: 0
  - speakerName: Volk
    speakerPortrait: {fileID: 0}
    text: ...
    isPlayerSpeaking: 1
  - speakerName: Volk
    speakerPortrait: {fileID: 0}
    text: Bir dahaki sefere soylerim.
    isPlayerSpeaking: 1
  - speakerName: Organizator
    speakerPortrait: {fileID: 0}
    text: VOLK turnuvasi kapanmistir. Bir sonraki sezonda gorusmek uzere!
    isPlayerSpeaking: 0
